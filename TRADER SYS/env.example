# =============================================================================
# TRADER-SYS — Deployment Settings (secrets + machine-specific only)
#
# Copy this file to `.env`, in this SAME directory (next to
# trading_bot.py / exchange.py) — never inside config/. Fill in real
# values. `.env` is gitignored — never commit it.
#
# This file intentionally does NOT contain trading strategy parameters
# (initial balance, timeframe, ranking/download/Kronos settings, etc.)
# — those live in config/trading.py, which you are expected to open
# and edit routinely. You should almost never need to touch this file
# after initial setup, unless credentials or the deployment machine
# itself change.
#
# Every variable below is read by config/config.py::load_config().
# Nothing in the codebase reads an environment variable that isn't
# listed here.
# =============================================================================

# ── Exchange credentials (REQUIRED) ──────────────────────────────────────────
# Binance API key/secret. Startup will fail fast if these do not
# authenticate (see config/config.py::validate_exchange_connectivity()).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ccxt exchange id. Optional — defaults to binance. The rest of this
# codebase (halal keyword list, min-notional extraction in exchange.py,
# fee-rate constants in risk_manager.py) assumes Binance's market-info
# shape; changing this without reviewing those assumptions is not
# supported by the current implementation.
EXCHANGE_ID=binance

# ── Machine-specific: Kronos inference device (optional) ─────────────────────
# Which physical device runs Kronos inference on THIS machine
# (e.g. cpu, cuda:0, mps). Leave unset to auto-detect (KronosPredictor's
# own default behavior). This is about hardware present on this
# deployment, not a trading strategy choice — that's why it lives here
# and not in config/trading.py.
# KRONOS_DEVICE=

# Optional — only needed if config/trading.py's Kronos repo ids ever
# point at a private/gated HuggingFace repo. Not read by this project's
# own code; huggingface_hub picks it up automatically from the
# environment if set.
# HF_TOKEN=

# ── Runtime paths (all optional — every path below derives from DATA_DIR
#    unless individually overridden; all directories are created
#    automatically at startup if missing). Machine-specific: where THIS
#    deployment stores its data. ────────────────────────────────────────────
DATA_DIR=./data
# ARTIFACTS_DIR=./data/artifacts
# TRADE_HISTORY_PATH=./data/journal/trade_history.csv
# POSITION_STATE_PATH=./data/state/position_state.json
# LOG_FILE=./data/logs/trading_bot.log

# ── Logging (optional) ───────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO
